{
  "name": "shiokiriyama.github.io",
  "description": "The source files of Shiokiriyama website.",
  "version": "0.2.3",
  "author": "Shiokiriyama",
  "bugs": {
    "url": "https://github.com/shiokiriyama/shiokiriyama.github.io/issues"
  },
  "devDependencies": {
    "fs-extra": "^11.3.6",
    "live-server": "^1.2.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.101.0",
    "terser": "^5.49.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "homepage": "https://shiokiriyama.github.io/",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/shiokiriyama/shiokiriyama.github.io.git"
  },
  "scripts": {
    "build": "run-s build:html build:sass build:ts build:jsmin",
    "build:html": "node bin/htmlminify.js",
    "build:jsmin": "terser docs/js/main.js -c -m -o docs/js/main.min.js",
    "build:sass": "sass src/scss/styles.scss docs/css/styles.min.css --style=compressed --no-source-map",
    "build:ts": "tsc",
    "dev": "run-p serve watch:*",
    "serve": "live-server docs --host=127.0.0.1 --port=5173 --watch=docs --no-browser",
    "watch:html": "node bin/htmlminify.js --watch",
    "watch:sass": "sass src/scss/styles.scss docs/css/styles.min.css --style=expanded --no-source-map --watch",
    "watch:ts": "tsc --watch"
  },
  "type": "module"
}
