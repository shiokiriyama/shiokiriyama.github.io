{
  "name": "shiokiriyama.github.io",
  "description": "The source files of Shiokiriyama website.",
  "version": "0.2.2",
  "author": "Shiokiriyama",
  "bugs": {
    "url": "https://github.com/shiokiriyama/shiokiriyama.github.io/issues"
  },
  "devDependencies": {
    "fs-extra": "^11.3.4",
    "live-server": "^1.2.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.98.0",
    "terser": "^5.46.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "homepage": "https://shiokiriyama.github.io/",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/shiokiriyama/shiokiriyama.github.io.git"
  },
  "scripts": {
    "build:html": "node bin/htmlminify.js",
    "build:jsmin": "terser docs/js/main.js -c -m -o docs/js/main.min.js",
    "build:sass": "sass src/scss/styles.scss docs/css/styles.min.css --style=compressed",
    "build:ts": "tsc",
    "dev": "run-p serve watch:*",
    "serve": "live-server docs --port=5173 --watch=docs --no-browser",
    "watch:html": "node bin/htmlminify.js --watch",
    "watch:sass": "sass src/scss/styles.scss docs/css/styles.min.css --style=compressed --watch",
    "watch:ts": "tsc --watch"
  },
  "type": "module"
}
